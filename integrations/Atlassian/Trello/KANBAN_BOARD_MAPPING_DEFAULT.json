            }
          },
          {
            "value": "video",
            "nls": {
              "en": {
                "NAME": "video"
              }
            }
          },
          {
            "value": "sound",
            "nls": {
              "en": {
                "NAME": "sound"
              }
            }
          },
          {
            "value": "mediaAsset",
            "nls": {
              "en": {
                "NAME": "mediaAsset"
              }
            }
          }
        ],
        "nls": {
          "en": {
            "NAME": "Attachments"
          }
        }
      },
      {
        "code": "KANBAN_DUE",
        "className": "java.time.LocalDateTime",
        "nls": {
          "en": {
            "NAME": "Due Date"
          }
        }
      },
      {
        "code": "KANBAN_START",
        "className": "java.time.LocalDateTime",
        "nls": {
          "en": {
            "NAME": "Start Date"
