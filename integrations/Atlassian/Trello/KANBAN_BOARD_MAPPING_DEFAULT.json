        "nls": {
          "en": {
            "NAME": "Source Board ID"
          }
        }
      },
      {
        "code": "KANBAN_SOURCE_UPDATED_AT",
        "className": "java.lang.String",
        "hidden": true,
        "nls": {
          "en": {
            "NAME": "Source Updated At"
          }
        }
      },
      {
        "code": "KANBAN_BOARD_MEMBERS",
        "className": "com.pixelnation.common.domain.User",
        "multiselect": true,
        "nls": {
          "en": {
            "NAME": "Board Members"
          }
        }
      }
    ]
  },
  "taskType": {
    "code": "GENERIC_KANBAN_TASK",
    "createIfMissing": true,
    "strictValidation": true,
    "nls": {
      "en": {
        "NAME": "Generic Kanban Task",
        "DESCRIPTION": "Imported Kanban card"
      }
    },
    "attributes": [
      {
        "code": "KANBAN_SOURCE_CARD_ID",
        "className": "java.lang.String",
        "hidden": true,
        "nls": {
          "en": {
            "NAME": "Source Card ID"
          }
        }
      },
      {
        "code": "KANBAN_SOURCE_LIST_ID",
        "className": "java.lang.String",
        "hidden": true,
        "nls": {
          "en": {
            "NAME": "Source List ID"
          }
        }
      },
      {
        "code": "KANBAN_SOURCE_UPDATED_AT",
        "className": "java.lang.String",
        "hidden": true,
        "nls": {
          "en": {
            "NAME": "Source Updated At"
          }
        }
      },
      {
        "code": "KANBAN_LABELS",
        "className": "java.lang.String",
        "multiselect": true,
        "freeValue": false,
        "options": [],
        "nls": {
          "en": {
            "NAME": "Labels"
          }
        }
      },
      {
        "code": "KANBAN_CHECKLISTS",
        "className": "java.lang.String",
        "multiselect": true,
        "nls": {
          "en": {
            "NAME": "Checklists"
          }
        }
      },
      {
        "code": "KANBAN_ATTACHMENTS",
