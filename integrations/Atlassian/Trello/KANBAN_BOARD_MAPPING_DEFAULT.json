          }
        }
      }
    ]
  },
  "projectWorkflow": {
    "code": "GENERIC_KANBAN_PROJECT_WORKFLOW",
    "createIfMissing": true,
    "entityType": "com.pixelnation.svc.domain.Project",
    "scriptLanguage": "Java",
    "nls": {
      "en": {
        "NAME": "Generic Kanban Project Workflow",
        "DESCRIPTION": "Project lifecycle for imported Kanban boards"
      }
    },
    "image": null,
    "style": {},
    "attributes": [],
    "attributeGroups": [],
    "attributeOrder": [],
    "initialState": "INITIAL",
    "states": [
      {
        "code": "INITIAL",
        "nls": {
          "en": {
            "NAME": "Initial"
          }
        },
        "image": null,
        "style": {},
        "attributes": [],
        "events": [
          {
            "code": "INITIAL_TO_ACTIVE",
            "target": "ACTIVE",
            "nls": {
              "en": {
                "NAME": "Activate"
              }
            },
            "image": null,
            "style": {},
            "attributes": []
          }
        ]
      },
      {
        "code": "ACTIVE",
        "nls": {
          "en": {
            "NAME": "Active"
          }
        },
        "image": null,
        "style": {},
        "attributes": [],
        "events": [
          {
            "code": "ACTIVE_TO_ARCHIVED",
            "target": "ARCHIVED",
            "nls": {
              "en": {
                "NAME": "Archive"
              }
            },
            "image": null,
            "style": {},
            "attributes": []
          }
        ]
      },
      {
        "code": "ARCHIVED",
        "nls": {
          "en": {
            "NAME": "Archived"
          }
        },
        "image": null,
        "style": {},
        "attributes": [],
        "events": [
          {
            "code": "ARCHIVED_TO_ACTIVE",
            "target": "ACTIVE",
            "nls": {
              "en": {
                "NAME": "Restore"
              }
            },
            "image": null,
            "style": {},
            "attributes": []
          }
        ]
      }
    ]
  },
  "taskWorkflow": {
    "code": "GENERIC_KANBAN_TASK_FLOW",
    "createIfMissing": true,
    "entityType": "com.pixelnation.svc.domain.Task",
    "scriptLanguage": "Java",
    "nls": {
      "en": {
        "NAME": "Generic Kanban Task Flow",
        "DESCRIPTION": "Task flow generated from source board lists"
      }
    },
    "image": null,
    "style": {},
    "attributes": [],
    "attributeGroups": [],
    "attributeOrder": [],
    "initialState": "INITIAL",
    "statesFrom": "$.lists",
    "stateCodePath": "$.name",
    "stateNamePath": "$.name",
    "includeArchivedState": true,
    "states": [],
    "events": {
      "mode": "ANY_STATE_TO_ANY_STATE",
      "definitions": []
    }
  },
  "mappings": {
    "project": {
      "fixedFields": [
        {
          "source": "$.name",
          "target": "nls.en.NAME"
        },
        {
          "source": "$.desc",
          "target": "nls.en.DESCRIPTION",
          "convert": "MARKDOWN_TO_HTML"
        }
      ],
      "attributes": [
        {
          "source": "$.id",
          "target": "KANBAN_SOURCE_BOARD_ID"
        }
      ]
    },
    "task": {
      "fixedFields": [
        {
          "source": "$.cards[*].name",
          "target": "nls.en.NAME"
        },
        {
          "source": "$.cards[*].desc",
          "target": "nls.en.DESCRIPTION",
          "convert": "MARKDOWN_TO_HTML"
        }
      ],
      "attributes": [
        {
          "source": "$.cards[*].id",
          "target": "KANBAN_SOURCE_CARD_ID"
        },
        {
          "source": "$.cards[*].idList",
          "target": "KANBAN_SOURCE_LIST_ID"
        }
      ]
    },
    "users": {
      "boardMembersAreProjectMembers": true,
      "createMissingUsers": true,
      "matchBy": [
        "email",
        "fullName",
        "username"
      ]
    },
    "media": {
      "downloadExternalUrls": true,
      "associateLibraryWithProject": true
    },
    "ignored": [
      {
        "path": "$.idOrganization",
        "reason": "Core organization is supplied by mapping/runtime context"
      },
      {
        "path": "$..shortLink",
        "reason": "Source short links are not useful Core data"
      },
      {
        "path": "$..shortUrl",
        "reason": "Source short URLs are not useful Core data"
      },
      {
        "path": "$..url",
        "reason": "Non-media page URLs are ignored unless traceability is enabled"
      }
    ]
  },
  "sync": {
    "identity": {
      "project": "$.id",
      "task": "$.cards[*].id",
      "state": "$.lists[*].id",
      "member": "$.members[*].id"
    },
    "deletePolicy": "ARCHIVE",
    "closedPolicy": "ARCHIVE",
    "missingCardPolicy": "ARCHIVE"
  }
}
