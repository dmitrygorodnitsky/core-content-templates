{
  "source": {
    "format": "KANBAN_BOARD_EXPORT",
    "vendor": "Atlassian",
    "product": "Trello",
    "version": 1
  },
  "organization": {
    "code": "SERVICEWAND"
  },
  "mediaLibrary": {
    "code": "SERVICE_WAND_KANBAN",
    "createIfMissing": true,
    "projectScoped": true,
    "codePattern": "${projectCode}_MEDIA",
    "downloadExternalUrls": true,
    "associateLibraryWithProject": true,
    "nls": {
      "en": {
        "NAME": "Kanban Import Media",
        "DESCRIPTION": "Media imported from external Kanban boards"
      }
    }
  },
  "contentConversion": {
    "sourceDescriptionFormat": "MARKDOWN",
    "targetDescriptionFormat": "HTML",
    "convertDescriptionsToHtml": true,
    "convertDialogMessagesToHtml": true
  },
  "projectType": {
    "code": "GENERIC_KANBAN",
    "createIfMissing": true,
    "strictValidation": true,
    "nls": {
      "en": {
        "NAME": "Generic Kanban Board",
        "DESCRIPTION": "Imported Kanban board"
      }
    },
    "attributes": [
      {
        "code": "TASK_TYPES",
        "className": "com.pixelnation.svc.domain.TaskType",
        "multiselect": true,
        "required": false,
        "hidden": false,
        "nls": {
          "en": {
            "NAME": "Task Types",
            "DESCRIPTION": "Task types allowed for projects of this type"
          }
        }
      },
      {
        "code": "KANBAN_SOURCE_BOARD_ID",
